{
  "name": "@nostr-ts/web",
  "version": "0.0.9",
  "description": "nostr in the browser",
  "author": "Franz Geffke <mail@gofranz.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/franzos/nostr-ts"
  },
  "keywords": [
    "nostr",
    "blockchain",
    "crypto"
  ],
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "tsc": "pnpm run build",
    "build": "pnpm run prebuild && node build.js && tsc -p tsconfig.json --emitDeclarationOnly",
    "check": "pnpm dlx madge --extensions ts --circular src/",
    "tests": "NODE_OPTIONS='--experimental-vm-modules' jest"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@nostr-ts/common": "workspace:*",
    "idb": "^8.0.3",
    "nanoid": "^5.1.7"
  },
  "devDependencies": {
    "@anatine/esbuild-decorators": "^0.2.19",
    "@types/jest": "^29.5.14",
    "esbuild": "^0.27.5",
    "esbuild-node-externals": "^1.20.1",
    "fake-indexeddb": "^6.2.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rimraf": "^3.0.2",
    "tslib": "2.8.1",
    "typescript": "5.8.3"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist/*"
  ]
}
