{
  "name": "@nostr-ts/common",
  "version": "0.0.9",
  "description": "Commonly used nostr types and utils",
  "author": "Franz Geffke <mail@gofranz.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/franzos/nostr-ts"
  },
  "keywords": [
    "nostr",
    "blockchain",
    "crypto"
  ],
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "tsc": "pnpm run build",
    "build": "pnpm run prebuild && node build.js && tsc -p tsconfig.json --emitDeclarationOnly",
    "check": "pnpm dlx madge --extensions ts --circular src/",
    "tests": "NODE_OPTIONS='--experimental-vm-modules' jest"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "bech32": "^2.0.0",
    "light-bolt11-decoder": "^3.2.0",
    "nanoid": "^5.1.7"
  },
  "devDependencies": {
    "@anatine/esbuild-decorators": "^0.2.19",
    "@jest/globals": "^30.3.0",
    "@types/jest": "^29.5.14",
    "crypto-browserify": "^3.12.1",
    "esbuild": "^0.27.5",
    "esbuild-node-externals": "^1.20.1",
    "jest": "^29.7.0",
    "rimraf": "^3.0.2",
    "ts-jest": "^29.4.9",
    "tslib": "2.8.1",
    "typescript": "5.8.3"
  },
  "main": "dist/index.esm.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/*"
  ],
  "gitHead": "67e2e9767eb307a0ef494800638d8d163db8cb6a"
}
